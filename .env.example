# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/moderation_db

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_with_another_long_random_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-replace_with_your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=15000

# ─── API Server ───────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Langfuse (optional — LLM observability) ──────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-replace_with_your_public_key
LANGFUSE_SECRET_KEY=sk-lf-replace_with_your_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Sentry (optional — application error monitoring & performance) ───────────
# API service vars
SENTRY_DSN=https://replace@o0.ingest.sentry.io/0
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=                          # e.g. git rev-parse --short HEAD
# Web service vars (NEXT_PUBLIC_ is baked into the browser bundle at build time)
NEXT_PUBLIC_SENTRY_DSN=https://replace@o0.ingest.sentry.io/0
# Build-time only — used for source map upload, not shipped in runtime image
SENTRY_AUTH_TOKEN=replace_with_sentry_auth_token
SENTRY_ORG=replace_with_sentry_org_slug
SENTRY_PROJECT=replace_with_sentry_project_slug

# ─── Postgres (Docker Compose) ────────────────────────────────────────────────
POSTGRES_DB=moderation_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
